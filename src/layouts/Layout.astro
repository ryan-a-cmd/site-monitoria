---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Navbar from "../components/common/Navbar.jsx";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  image?: string;
  hideNavbar?: boolean;
}

const {
  title,
  description = "Site oficial da Monitoria de TI do CEUB. Construindo conhecimento na prática através de oficinas e projetos para os cursos de Ciência da Computação, Engenharia de Software, Engenharia de Computação e Análise e Desenvolvimento de Sistemas (ADS).",
  bodyClass = "",
  image = "/site-preview.jpg",
  hideNavbar = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="google-site-verification"
      content="FdZBgSJ3j28WC4x9Rph0xUoEI-T_HBMZU0H2EgFz2o4"
    />
    <meta
      name="keywords"
      content="Monitoria CEUB, Monitoria TI CEUB, CEUB, Centro Universitário de Brasília, Ciência da Computação, Engenharia de Software, Engenharia de Computação, Análise e Desenvolvimento de Sistemas, ADS, Tecnologia, Oficinas de TI"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Monitoria de TI - CEUB" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url).href} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url).href} />

    <!-- Canonical URL -->
    <link
      rel="canonical"
      href={new URL(currentPath, Astro.site || Astro.url).href}
    />

    <meta name="theme-color" content="#662c92" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link
      rel="preload"
      href="/fonts/NotoSans-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    <ClientRouter />

    <script type="application/ld+json" is:inline>
      [
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "name": "Monitoria de TI - CEUB",
          "url": "https://site-monitoria-blue.vercel.app/"
        },
        {
          "@context": "https://schema.org",
          "@type": "EducationalOrganization",
          "name": "Monitoria de TI - CEUB",
          "url": "https://site-monitoria-blue.vercel.app/",
          "description": "Monitoria de Tecnologia da Informação do Centro Universitário de Brasília (CEUB), oferecendo suporte e oficinas para os cursos de Ciência da Computação, Engenharia de Software, Engenharia de Computação e Análise e Desenvolvimento de Sistemas (ADS).",
          "parentOrganization": {
            "@type": "CollegeOrUniversity",
            "name": "Centro Universitário de Brasília - CEUB",
            "url": "https://www.uniceub.br/"
          }
        }
      ]
    </script>
  </head>
  <body class={bodyClass}>
    {
      !hideNavbar && (
        <Navbar
          client:idle
          transition:persist="navbar"
          currentPath={currentPath}
        />
      )
    }
    <slot />
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    background-color: #1a1a1a;
    -webkit-font-smoothing: antialiased;
  }

  body.theme-light {
    background-color: #fdfdfd !important;
    color: #1a1a24;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
