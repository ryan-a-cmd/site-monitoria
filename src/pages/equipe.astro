---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/common/Footer.astro";
import MonitorCard from "../components/equipe/MonitorCard.astro";
import { equipeData } from "../data/equipe.js";
import EquipeHero from "../components/equipe/EquipeHero.astro";

const ordenarPorNome = (a: { nome: string }, b: { nome: string }) => {
  return a.nome.localeCompare(b.nome, "pt-BR");
};

const monitoresAtivos = equipeData
  .filter((m) => m.ativo && !m.ocultarNaEquipe)
  .sort(ordenarPorNome);

const exMembros = equipeData.filter((m) => !m.ativo).sort(ordenarPorNome);
---

<Layout
  title="Equipe de Monitores | Monitoria de TI - CEUB"
  description="Conheça a equipe atual e os ex-membros da Monitoria de TI do CEUB. Alunos engajados em ajudar, mentorar e compartilhar conhecimento na área de tecnologia."
>
  <main class="equipe-page">
    <EquipeHero
      preTexto="Conheça nossa"
      titulo="Equipe"
      subTexto="Um time que orienta, apoia e transforma."
    />

    <div class="container main-content">
      <section class="team-section">
        <div class="section-header">
          <h2>Conheça nossa equipe</h2>
          <div class="divider"></div>
        </div>

        <div class="monitores-grid">
          {
            monitoresAtivos.map((monitor, index) => (
              <MonitorCard
                nome={monitor.nome}
                descricao={monitor.descricao}
                foto={monitor.foto}
                loading={index < 8 ? "eager" : "lazy"}
                linkedin={monitor.linkedin}
                github={monitor.github}
                codeberg={monitor.codeberg}
              />
            ))
          }
        </div>
      </section>

      {
        exMembros.length > 0 && (
          <section class="team-section ex-membros-section">
            <div class="section-header">
              <h2>Ex-Membros da Monitoria</h2>
              <div class="divider" />
            </div>

            <div class="monitores-grid">
              {exMembros.map((monitor) => (
                <MonitorCard
                  nome={monitor.nome}
                  descricao={monitor.descricao}
                  foto={monitor.foto}
                  isExMembro={true}
                  linkedin={monitor.linkedin}
                  github={monitor.github}
                  codeberg={monitor.codeberg}
                />
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .equipe-page {
    background-color: #fafafe;
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .main-content {
    margin-top: -40px;
    position: relative;
    z-index: 10;
    padding-bottom: 100px;
  }

  .team-section {
    background: #ffffff;
    border-radius: 24px;
    padding: 4rem 2rem;
    box-shadow: 0 10px 40px rgba(102, 44, 146, 0.05);
    margin-bottom: 4rem;
  }

  .ex-membros-section {
    background: transparent;
    box-shadow: none;
    padding: 2rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-header h2 {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    color: #0d041a;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--purple-primary);
    border-radius: 2px;
  }

  .monitores-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 2rem;
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 768px) {
    .team-section {
      padding: 2.5rem 1.5rem;
    }
    .container {
      padding: 0 1rem;
    }
    .main-content {
      margin-top: -20px;
    }
  }
</style>
