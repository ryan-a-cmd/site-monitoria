---
import { Image } from "astro:assets";

import imgOficinas from "@assets/mago/mago-oficina.png";
import imgProjetos from "@assets/mago/mago-acidentando.png";
import imgApoio from "@assets/mago/mago-working.png";

const iniciativas = [
  {
    title: "Oficinas",
    description: "Descubra o que ensinamos em nossas oficinas práticas.",
    image: imgOficinas,
    alt: "Mago dando aula em um quadro verde",
    link: "/oficinas",
    isExternal: false,
  },
  {
    title: "Projetos",
    description: "Conheça as ideias que construímos em conjunto.",
    image: imgProjetos,
    alt: "Mago se acidentando",
    link: "/pitaco",
    isExternal: false,
  },
  {
    title: "Apoio Acadêmico",
    description: "Saiba como podemos te ajudar a superar suas dificuldades.",
    image: imgApoio,
    alt: "Mago trabalhando focado em uma mesa de escritório",
    link: "https://linktr.ee/monitoriaticeub",
    isExternal: true,
  },
];
---

<section
  class="iniciativas-section"
  id="iniciativas"
  aria-labelledby="iniciativas-title"
>
  <div class="container">
    <div class="section-header">
      <span class="tag">Nossas Frentes</span>
      <h2 id="iniciativas-title">O que nós fazemos</h2>
      <p class="subtitle">
        Conheça as principais iniciativas da monitoria para impulsionar o seu
        aprendizado.
      </p>
    </div>

    <div class="cards-grid">
      {
        iniciativas.map((item) => (
          <a
            href={item.link}
            target={item.isExternal ? "_blank" : undefined}
            rel={item.isExternal ? "noopener noreferrer" : undefined}
            class="card-link"
          >
            <article class="card">
              <div class="click-indicator">
                <div class="indicator-content">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M7 17L17 7M17 7H7M17 7V17" />
                  </svg>
                  <span class="indicator-text">Clique para explorar</span>
                </div>
              </div>
              <div class="card-image-wrapper">
                <Image
                  src={item.image}
                  alt={item.alt}
                  class="card-image"
                  quality={70}
                  format="webp"
                  widths={[300, 600]}
                  sizes="(max-width: 600px) 300px, 600px"
                />
              </div>
              <div class="card-content">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .iniciativas-section {
    background: linear-gradient(to bottom, var(--bg-dark), #160824);
    padding: 100px 2rem 50px 2rem;
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tag {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(210, 168, 255, 0.1);
    color: var(--purple-neon);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    border: 1px solid rgba(210, 168, 255, 0.2);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text-main);
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 600px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .card-link {
    text-decoration: none;
    display: block;
  }

  .card {
    background: rgba(102, 44, 146, 0.15);
    border: 1px solid rgba(210, 168, 255, 0.12);
    border-radius: 16px;
    overflow: clip;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: relative;
  }

  @keyframes bounce-in {
    0% {
      opacity: 0;
      transform: scale(0) translateY(20px);
    }
    70% {
      opacity: 1;
      transform: scale(1.1) translateY(-3px);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes glow-pulse {
    0%, 100% {
      filter: drop-shadow(0 0 4px rgba(210, 168, 255, 0.4));
    }
    50% {
      filter: drop-shadow(0 0 12px rgba(210, 168, 255, 0.8));
    }
  }

  @keyframes typewriter {
    0% {
      max-width: 0;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    100% {
      max-width: 250px;
      opacity: 1;
    }
  }

  .indicator-content {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--purple-neon);
    opacity: 0;
    transform: scale(0) translateY(20px);
    width: fit-content;
  }

  .indicator-content svg {
    display: block;
    flex-shrink: 0;
  }

  .indicator-text {
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    letter-spacing: 0.5px;
  }

  .click-indicator {
    position: absolute;
    bottom: 16px;
    right: 16px;
    z-index: 30;
    pointer-events: none;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .card-link:hover .indicator-content {
    animation: bounce-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards, glow-pulse 1.5s ease-in-out infinite 0.3s;
  }

  .card-link:hover .indicator-text {
    animation: typewriter 1.2s ease-out 0.3s forwards;
  }

  .card:hover {
    transform: translateY(-8px);
    border-color: rgba(210, 168, 255, 0.5);
    box-shadow:
      0 15px 30px rgba(0, 0, 0, 0.4),
      0 0 25px rgba(102, 44, 146, 0.3);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #1a1a1a;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card:hover .card-image {
    transform: scale(1.03);
  }

  .card-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-content h3 {
    color: var(--text-main);
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
    font-weight: 600;
  }

  .card-content p {
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    margin-bottom: 2rem;
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 900px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .iniciativas-section {
      padding: 60px 1.5rem;
    }
    .cards-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
