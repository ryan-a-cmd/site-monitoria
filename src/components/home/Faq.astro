---
import { faqs } from "@data/faq.js";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.pergunta,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.resposta,
    },
  })),
};
---

<section class="faq-section" id="faq" aria-labelledby="faq-title">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
    is:inline
  />
  <div class="container">
    <div class="section-header">
      <span class="tag">Tire suas dúvidas</span>
      <h2 id="faq-title">Perguntas Frequentes</h2>
    </div>

    <div class="faq-list">
      {
        faqs.map((faq) => (
          <details class="faq-item" name="faq-accordion">
            <summary class="faq-question">
              {faq.pergunta}
              <span class="icon-wrapper">
                <svg
                  class="chevron"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </span>
            </summary>
            <div class="faq-answer">
              <p>{faq.resposta}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-section {
    background-color: var(--bg-dark);
    padding: 100px 2rem 50px 2rem;
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tag {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(210, 168, 255, 0.1);
    color: var(--purple-neon);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    border: 1px solid rgba(210, 168, 255, 0.2);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: var(--text-main);
    font-weight: 700;
    letter-spacing: -1px;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .faq-item:hover {
    border-color: rgba(210, 168, 255, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question {
    padding: 1.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-secondary);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: color 0.2s ease;
  }

  .faq-item:hover .faq-question {
    color: var(--text-main);
  }

  .icon-wrapper {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(210, 168, 255, 0.1);
    color: var(--purple-neon);
    transition: all 0.3s ease;
  }

  .chevron {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  details[open].faq-item {
    border-color: var(--purple-neon);
    background: rgba(102, 44, 146, 0.1);
  }

  details[open] .faq-question {
    color: var(--text-main);
  }

  details[open] .icon-wrapper {
    background: var(--purple-neon);
    color: var(--bg-dark);
  }

  details[open] .chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem 1.5rem;
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 1rem;
    animation: fadeInDown 0.3s ease-in-out forwards;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 768px) {
    .faq-section {
      padding: 60px 1.5rem 40px 1.5rem;
    }
    .faq-question {
      font-size: 1rem;
      padding: 1.2rem;
    }
    .faq-answer {
      padding: 0 1.2rem 1.2rem 1.2rem;
      font-size: 0.95rem;
    }
  }
</style>
