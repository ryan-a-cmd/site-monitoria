---
import { Image } from "astro:assets";
import imgMagosTrabalhando from "@assets/mago/oficinas/magos-trabalhando.png";
import { oficinasAtivasTaguatingaData } from "@data/oficinas-ativas-taguatinga.js";

const placeholders = [1, 2, 3];
---

<section class="taguatinga-section ativas" id="taguatinga-ativas">
  <div class="container">
    <div class="section-header">
      <h2>Oficinas Disponíveis <br /> Campus Taguatinga</h2>
      <div class="divider"></div>
    </div>

    <div class="cards-grid">
      {
        oficinasAtivasTaguatingaData.map((oficina) => (
          <article class="card">
            <div class="card-image-wrapper">
              <Image
                src={oficina.imagem}
                alt={oficina.alt}
                class="card-image"
                quality={70}
                format="webp"
              />
              <div class="badges-overlay">
                <span class={`badge-formato ${oficina.formato.toLowerCase()}`}>
                  {oficina.formato}
                </span>
              </div>
            </div>

            <div class="card-content">
              <h3>{oficina.titulo}</h3>
              <p class="descricao">{oficina.descricao}</p>

              <div class="info-horario">
                {oficina.turmas.map((turma) => (
                  <div class="info-item">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    <span>{turma}</span>
                  </div>
                ))}
              </div>

              <a href={oficina.linkInscricao} class="btn-inscrever">
                Clique para saber mais
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section class="taguatinga-section passadas" id="taguatinga-passadas">
  <div class="container">
    <div class="section-header">
      <h2>Oficinas Passadas <br /> Campus Taguatinga</h2>
      <div class="divider"></div>
    </div>

    <div class="cards-grid">
      {
        placeholders.map(() => (
          <article class="card-placeholder">
            <div class="card-image-wrapper">
              <Image
                src={imgMagosTrabalhando}
                alt="Magos trabalhando nas futuras oficinas de Taguatinga"
                class="card-image"
                quality={70}
                format="webp"
              />
            </div>
            <div class="card-content">
              <button class="btn-em-breve-fantasma" disabled>
                Em breve
              </button>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .taguatinga-section {
    padding: 80px 2rem;
    position: relative;
    z-index: 10;
  }

  .taguatinga-section.ativas {
    background-color: #ffffff;
  }

  .taguatinga-section.passadas {
    background-color: #fafafa;
    padding-bottom: 100px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h2 {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    color: var(--text-dark);
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--purple-primary);
    border-radius: 2px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    justify-content: center;
  }

  /* ESTILOS CARD ATIVO */
  .card {
    background: #ddd1ff;
    border: none;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 25px rgba(59, 0, 77, 0.15);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    position: relative;
    overflow: hidden;
    background: var(--bg-light);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card:hover .card-image {
    transform: scale(1.05);
  }

  .badges-overlay {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .badge-formato {
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  .badge-formato.presencial {
    background: #8b33cf;
    color: #ffffff;
  }

  .badge-formato.online {
    background: #2e7d32;
    color: #ffffff;
  }

  .card-content {
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-content h3 {
    color: #3b004d;
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .descricao {
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .info-horario {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(59, 0, 77, 0.1);
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    color: #555555;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .info-item svg {
    color: #7a1a8f;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .btn-inscrever {
    display: block;
    width: 100%;
    padding: 12px 0;
    background: var(--purple-primary);
    border: none;
    color: #ffffff;
    text-align: center;
    border-radius: 8px;
    font-weight: 600;
    text-transform: none;
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: auto;
    box-shadow: 0 4px 10px rgba(102, 44, 146, 0.2);
  }

  .btn-inscrever:hover {
    background: #7a1a8f;
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(122, 26, 143, 0.3);
  }

  /* ESTILOS CARD PLACEHOLDER (EM BREVE) */
  .card-placeholder {
    background: #ddd1ff;
    border: none;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }
  
  .card-placeholder .card-image-wrapper {
    aspect-ratio: 4 / 3;
    background: #a9d6ff;
  }

  .card-placeholder .card-content {
    padding: 1.2rem;
    display: flex;
    justify-content: center;
  }

  .btn-em-breve-fantasma {
    display: block;
    width: 100%;
    padding: 10px 0;
    background: transparent;
    border: 1px solid var(--purple-primary);
    color: var(--purple-primary);
    text-align: center;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: not-allowed;
    transition: all 0.3s ease;
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 600px) {
    .taguatinga-section {
      padding: 60px 1.5rem;
    }

    .taguatinga-section.passadas {
      padding-bottom: 80px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .card-placeholder:nth-child(n + 2) {
      display: none;
    }
  }
</style>
