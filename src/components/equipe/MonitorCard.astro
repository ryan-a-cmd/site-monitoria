---
import { Image } from "astro:assets";

interface Props {
  nome: string;
  descricao: string;
  foto: any;
  isExMembro?: boolean;
  loading?: "eager" | "lazy";
  linkedin?: string | null;
  github?: string | null;
  codeberg?: string | null;
}

const {
  nome,
  descricao,
  foto,
  isExMembro = false,
  loading = "lazy",
  linkedin = null,
  github = null,
  codeberg = null,
} = Astro.props;
---

<article class={`monitor-card ${isExMembro ? "ex-membro-card" : ""}`}>
  <div class="social-buttons">
    {
      linkedin ? (
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="social-btn social-btn-primary"
          aria-label={`LinkedIn de ${nome}`}
          title={`LinkedIn de ${nome}`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z" />
          </svg>
        </a>
      ) : (
        <span
          class="social-btn social-btn-disabled"
          aria-label={`LinkedIn de ${nome} não disponível`}
          title="LinkedIn não disponível"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z" />
          </svg>
        </span>
      )
    }

    {
      codeberg ? (
        <a
          href={codeberg}
          target="_blank"
          rel="noopener noreferrer"
          class="social-btn social-btn-dark"
          aria-label={`Codeberg de ${nome}`}
          title={`Codeberg de ${nome}`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 4.2333332 4.2333335"
            aria-hidden="true"
            fill="currentColor"
          >
            <g transform="matrix(0.06551432,0,0,0.06551432,-2.232417,-1.431776)">
              <path
                d="m 42519.285,-7078.7891 a 0.76086879,0.56791688 0 0 0 -0.738,0.6739 l 33.586,125.8886 a 87.182358,87.182358 0 0 0 39.381,-33.7636 l -71.565,-92.5196 a 0.76086879,0.56791688 0 0 0 -0.664,-0.2793 z"
                transform="matrix(0.37058478,0,0,0.37058478,-15690.065,2662.0533)"
              />
              <path
                d="m 11249.461,-1883.6961 c -12.74,0 -23.067,10.3275 -23.067,23.0671 0,4.3335 1.22,8.5795 3.522,12.2514 l 19.232,-24.8636 c 0.138,-0.1796 0.486,-0.1796 0.624,0 l 19.233,24.8646 c 2.302,-3.6721 3.523,-7.9185 3.523,-12.2524 0,-12.7396 -10.327,-23.0671 -23.067,-23.0671 z"
                transform="matrix(1.4006354,0,0,1.4006354,-15690.065,2662.0533)"
              />
            </g>
          </svg>
        </a>
      ) : github ? (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="social-btn social-btn-dark"
          aria-label={`GitHub de ${nome}`}
          title={`GitHub de ${nome}`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8" />
          </svg>
        </a>
      ) : (
        <span
          class="social-btn social-btn-disabled"
          aria-label={`GitHub de ${nome} não disponível`}
          title="GitHub não disponível"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8" />
          </svg>
        </span>
      )
    }
  </div>

  <div class={`monitor-foto-wrapper ${isExMembro ? "grayscale" : ""}`}>
    <Image
      src={foto}
      alt={`Foto de ${nome}`}
      class="monitor-foto"
      loading={loading}
      quality={80}
      format="webp"
    />
  </div>
  <h3>{nome}</h3>
  <p class="descricao" set:html={descricao} />
</article>

<style>
  .monitor-card {
    background: #faf9fc;
    border: 2px solid #e0d1ff;
    border-radius: 16px;
    padding: 2.5rem 1.5rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    box-shadow: 0 5px 15px rgba(102, 44, 146, 0.04);
    position: relative;
  }

  .monitor-card:hover {
    border-color: #cab0ff;
    box-shadow: 0 15px 30px rgba(102, 44, 146, 0.08);
    transform: translateY(-4px);
  }

  .ex-membro-card {
    background: #f0f0f0;
    border-color: #e0e0e0;
    box-shadow: none;
  }

  .ex-membro-card:hover {
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
    transform: translateY(-4px);
  }

  /* Linha dos botões sociais */
  .social-buttons {
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    pointer-events: none;
  }

  .social-btn {
    pointer-events: auto;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }

  /* Botão ativo do LinkedIn */
  .social-btn-primary {
    background-color: #0072b1;
    color: #ffffff;
    box-shadow: 0 2px 6px rgba(0, 114, 177, 0.35);
  }

  .social-btn-primary:hover {
    background-color: #005c8f;
    transform: scale(1.1);
    box-shadow: 0 4px 10px rgba(0, 114, 177, 0.5);
  }

  /* Botão ativo do GitHub */
  .social-btn-dark {
    background-color: #24292e;
    color: #ffffff;
    box-shadow: 0 2px 6px rgba(36, 41, 46, 0.35);
  }

  .social-btn-dark:hover {
    background-color: #1a1e22;
    transform: scale(1.1);
    box-shadow: 0 4px 10px rgba(36, 41, 46, 0.5);
  }

  /* Botão desabilitado (sem link) */
  .social-btn-disabled {
    background-color: #cccccc;
    color: #999999;
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Adaptação para ex-membros: botões ainda mais discretos */
  .ex-membro-card .social-btn-disabled {
    opacity: 0.35;
  }

  .monitor-foto-wrapper {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(
      135deg,
      var(--purple-primary),
      var(--accent-pink)
    );
    margin-bottom: 1.5rem;
    margin-top: 0.75rem;
    box-shadow: 0 8px 15px rgba(232, 28, 97, 0.2);
  }

  .monitor-foto-wrapper.grayscale {
    background: linear-gradient(135deg, #999, #ccc);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .monitor-foto {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #ffffff;
    background-color: #ffffff;
  }

  .monitor-card h3 {
    color: #3b004d;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }

  .monitor-card .descricao {
    color: #555555;
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
